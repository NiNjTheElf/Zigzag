{
  "hosting": {
    "site": "zigzag-hairplace-ae551",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git/**",
      ".firebase/**",
      "**/node_modules/**",
      ".agents/**",
      ".chrome-preview*/**",
      ".edge-preview/**",
      "functions/**",
      "uploads/**",
      "server.js",
      "package.json",
      "package-lock.json",
      "database.sql",
      "skills-lock.json",
      "update_barbers.js",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(woff2|png|jpg|jpeg|gif|webp|svg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
