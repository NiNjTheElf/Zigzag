generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BOSS
  SENIOR_BARBER
  BARBER
  JUNIOR_BARBER
}

// 2. Update the User Model
model User {
  id               Int           @id @default(autoincrement())
  name             String
  email            String        @unique
  password         String
  role             UserRole      @default(BARBER) // Use the Enum here
  bio              String?
  instagram        String?
  tiktok           String?
  profilePhotoUrl  String?       @map("profile_photo_url")
  photoUrls        String[]      @default([])
  services         String?
  createdAt        DateTime?     @default(now()) @map("created_at")
  appointments     Appointment[] @relation("BarberAppointments")
  dayOffs          DayOff[]
  reviews          Review[]

  @@map("users")
}

model Appointment {
  id               Int       @id @default(autoincrement())
  barberId         Int?
  clientName       String?   @map("client_name")
  clientPhone      String?   @map("client_phone")
  appointmentDate  DateTime? @db.Date @map("appointment_date")
  appointmentTime  String?   @map("appointment_time")
  serviceType      String?   @map("service_type")
  createdAt        DateTime? @default(now()) @map("created_at")
  barber           User?     @relation("BarberAppointments", fields: [barberId], references: [id])

  @@map("appointments")
}

model DayOff {
  id                    Int       @id @default(autoincrement())
  barberId              Int?
  dayOffDate            DateTime? @db.Date @map("day_off_date")
  isRecurring           Boolean?  @default(false) @map("is_recurring")
  recurringDayOfWeek    Int?      @map("recurring_day_of_week")
  notes                 String?
  createdAt             DateTime? @default(now()) @map("created_at")
  barber                User?     @relation(fields: [barberId], references: [id])

  @@map("day_offs")
}

model Review {
  id             Int       @id @default(autoincrement())
  barberId       Int
  clientName     String?   @map("client_name")
  clientPhone    String?   @map("client_phone")
  reviewerName   String?   @map("reviewer_name")
  reviewerPhone  String?   @map("reviewer_phone")
  rating         Int
  comment        String?
  reviewText     String?   @map("review_text")
  createdAt      DateTime? @default(now()) @map("created_at")
  barber         User      @relation(fields: [barberId], references: [id])

  @@map("reviews")
}
